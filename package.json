{
  "name": "quovibe",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "lint": "eslint packages --max-warnings=50",
    "lint:engine": "eslint packages/engine/src/ --max-warnings=0",
    "check:governance": "tsx scripts/check-governance.ts",
    "check:arch": "tsx scripts/check-architecture.ts",
    "check:all": "pnpm build && pnpm test && pnpm lint:engine && pnpm check:governance && pnpm check:arch",
    "preflight": "bash scripts/preflight.sh",
    "postflight": "bash scripts/postflight.sh",
    "changelog:draft": "bash scripts/generate-changelog-entry.sh",
    "typecheck": "pnpm -r build",
    "test:e2e": "pnpm --filter @quovibe/e2e exec playwright test",
    "ci": "bash scripts/ci.sh",
    "ci:full": "bash scripts/ci.sh --e2e"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "glob": "^13.0.6",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "packageManager": "pnpm@9.0.0"
}
