# Portfolio data directory — parent of every portfolio-<uuid>.db and the
# quovibe.settings.json sidecar. Override only for non-standard deployments;
# the default is the monorepo's ./data folder.
# QUOVIBE_DATA_DIR=./data

# Backup retention — maximum number of rotated .bak.<ts> files kept per
# portfolio .db file (older ones are deleted after each new backup).
DB_BACKUP_MAX=3

# Maximum number of simultaneously open per-portfolio SQLite handles in the
# connection pool (least-recently-used entries are closed when over limit).
PORTFOLIO_POOL_MAX=5

# Maximum .db / .xml upload size accepted by the import endpoint.
IMPORT_MAX_MB=50

# Demo source — path the API copies from when a user selects "Try demo".
# Docker sets this to /app/assets/demo.db; dev default is ./data/demo.db.
# QUOVIBE_DEMO_SOURCE=./data/demo.db

# Server
PORT=3000
NODE_ENV=development

# Prices (optional)
ECB_RATES_URL=https://data.ecb.europa.eu/stats/policy_and_exchange_rates

# Rate limiting for price fetching
PRICE_FETCH_INTERVAL_MS=1000
PRICE_FETCH_MAX_CONCURRENT=5

# Logging
LOG_LEVEL=info
