# Database
DB_PATH=./data/portfolio.db
DB_BACKUP_MAX=3

# Server
PORT=3000
NODE_ENV=development

# Prices (optional)
ECB_RATES_URL=https://data.ecb.europa.eu/stats/policy_and_exchange_rates

# Rate limiting for price fetching
PRICE_FETCH_INTERVAL_MS=1000
PRICE_FETCH_MAX_CONCURRENT=5

# Background price job (node-cron schedule)
PRICE_CRON_SCHEDULE="0 18 * * 1-5"

# Logging
LOG_LEVEL=info
